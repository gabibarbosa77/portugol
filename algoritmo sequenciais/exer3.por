programa {
  funcao inicio() {
    inteiro largura, altura, comprimento, volume

    escreva("Entre com a largura da figura: ")
    leia(largura)

    escreva("Entre com a altura da figura:")
    leia(altura)
    
    escreva("Entre com a comprimento da figura:")
    leia(comprimento)

    volume= comprimento * largura * altura

    escreva("O volume da figura é " , volume)
    
  }
}
