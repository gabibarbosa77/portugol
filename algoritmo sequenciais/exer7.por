programa {
  funcao inicio() {

    inteiro distancia, velocidadeMedia, tempo

    escreva("Entre com a distância da viagem em km: ")
    leia(distancia)

    escreva("Entre com a velocidade média da viagem km/h: ")
    leia(velocidadeMedia)

    tempo = distancia / velocidadeMedia

    escreva("O tempo necessário para realizar a viagem é " , tempo , " horas")
    
  }
}
