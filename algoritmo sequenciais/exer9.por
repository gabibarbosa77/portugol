programa {
  funcao inicio() {
    inteiro diasHospedagem, valorTotal
    real valorDiaria

    escreva("Entre com o valor da diária: ")
    leia(valorDiaria)

    escreva("Entre com o número de dias da hospedagem: ")
    leia(diasHospedagem)

    valorTotal = valorDiaria * diasHospedagem

    escreva("O valor total a ser pago da hospedagem é " , valorTotal)
    
  }
}
