programa {
  funcao inicio() {
    inteiro hora
    real    valorHora
    real    salario

    escreva("Entre com a quantidade de horas trabalhadas no mês: ")
    leia(hora)

    escreva("Entre com o valor por hora: ")
    leia(valorHora)

    salario= hora*valorHora

    escreva("Seu salário baseado nas informações oferecidas é ", salario)
    
  }
}
