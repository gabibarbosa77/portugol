programa {
  funcao inicio() {
    cadeia prod
    real preco
    inteiro estoq

    escreva("nome do produto: ")
    leia(prod)

    escreva("preço do produto: ")
    leia(preco)

    escreva("estoque: ")
    leia(estoq)

    escreva("Produto: " , prod  , "\n")
    escreva("Preço: "   , preco , "\n")
    escreva("Estoque: " , estoq , "\n")
  }
}
