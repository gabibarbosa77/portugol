programa {
  funcao inicio() {
    cadeia nome
    cadeia curso
    cadeia cidade

    escreva("digite seu nome: ")
    leia(nome)

    escreva("digite seu curso: ")
    leia(curso)

    escreva("digite sua cidade: ")
    leia(cidade)

    escreva(nome , "\n")
    escreva(curso , "\n")
    escreva(cidade)
    
  }
}
